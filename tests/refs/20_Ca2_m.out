        "<grep '!r' t1" using 2:4 title "rhoC" with lines ls 2,\
        "<grep '!r' t1" using 2:5 title "rhoM" with lines ls 3


pause -1 "Hit enter to continue"

set title "t2   Kinetic Energy Densities"

set xlabel "Radius (a_B)"

set  logscale y

plot    "<grep '!t' t1" using 2:3 title "tauPS" with lines ls 1,\
        "<grep '!t' t1" using 2:4 title "tau(M+PS)" with lines ls 9

unset  logscale y


pause -1 "Hit enter to continue"

set title "t2   Vtaus (Ha / a_B)"

set xlabel "Radius (a_B)"

set  logscale x

set xrange [0.1:20]

plot    "<grep '!vt' t1" using 2:3 title "VtauAE" with lines ls 1,\
        "<grep '!vt' t1" using 2:4 title "Vtau(M+PS)" with lines ls 9

set autoscale x

unset  logscale x


pause -1 "Hit enter to continue"

set title "t2   Wave Function set 1, E=   -1.78 Ha"

set xlabel "Radius (a_B)"

plot    "<grep '&    10' t1" using 3:4 title "S full" with lines ls 1,\
        "<grep '&    10' t1" using 3:5 title "S pseudo" with lines ls 8

pause -1 "Hit enter to continue"

