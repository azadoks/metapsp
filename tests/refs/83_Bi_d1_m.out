set title "t2   Wave Function set 2, E=    4.16 Ha"

set xlabel "Radius (a_B)"

plot    "<grep '&    23' t1" using 3:4 title "F full" with lines ls 1,\
        "<grep '&    23' t1" using 3:5 title "F pseudo" with lines ls 8

pause -1 "Hit enter to continue"

set title "t2   Wave Function set 3, E=   14.76 Ha"

set xlabel "Radius (a_B)"

plot    "<grep '&    33' t1" using 3:4 title "F full" with lines ls 1,\
        "<grep '&    33' t1" using 3:5 title "F pseudo" with lines ls 8

pause -1 "Hit enter to continue"

set xlabel "Radius (a_B)"

set title "t2   F Projs. evkb(:) =  -4.18E+01  -2.35E+01  -5.97E+00 Ha"

plot    "<grep '!J     3' t1" using 3:4 title "Prj 1" with lines ls 1,\
        "<grep '!J     3' t1" using 3:5 title "Prj 2" with lines ls 2,\
        "<grep '!J     3' t1" using 3:6 title "Prj 3" with lines ls 3


pause -1 "Hit enter to continue"

set title "t2   ARCTAN(Log Derivatives)"

set xlabel "Energy (Ha)"

plot    "<grep '!      3' t1" using 3:4 title "F   full" with lines ls 1,\
        "<grep '!      3' t1" using 3:5 title "F pseudo" with lines ls 8

pause -1 "Hit enter to continue"

set  logscale y

set  grid

set  yrange [5.e-6:2.e-2]

set title "t2   Energy Error per Electron (Ha)"

set xlabel "Cutoff Energy (Ha)"

plot    "<grep '!C     0' t1" using 3:4 title "S" with lines ls 1,\
        "<grep '!C     1' t1" using 3:4 title "P" with lines ls 2,\
        "<grep '!C     2' t1" using 3:4 title "D" with lines ls 3,\
        "<grep '!C     3' t1" using 3:4 title "F" with lines ls 4


pause -1 "Hit enter to continue"

END_GNU
