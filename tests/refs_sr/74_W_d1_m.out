        "<grep '&    30' t1" using 3:5 title "S pseudo" with lines ls 8

pause -1 "Hit enter to continue"

set xlabel "Radius (a_B)"

set title "t2   S Projs. evkb(:) =   8.19E+00  -6.03E+00   7.22E-01 Ha"

plot    "<grep '!J     0' t1" using 3:4 title "Prj 1" with lines ls 1,\
        "<grep '!J     0' t1" using 3:5 title "Prj 2" with lines ls 2,\
        "<grep '!J     0' t1" using 3:6 title "Prj 3" with lines ls 3


pause -1 "Hit enter to continue"

