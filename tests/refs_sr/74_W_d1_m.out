set xlabel "Energy (Ha)"

plot    "<grep '!      0' t1" using 3:4 title "S   full" with lines ls 1,\
        "<grep '!      0' t1" using 3:5 title "S pseudo" with lines ls 8

pause -1 "Hit enter to continue"

