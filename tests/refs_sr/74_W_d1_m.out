plot    "<grep '!J     3' t1" using 3:4 title "Prj 1" with lines ls 1,\
        "<grep '!J     3' t1" using 3:5 title "Prj 2" with lines ls 2,\
        "<grep '!J     3' t1" using 3:6 title "Prj 3" with lines ls 3


pause -1 "Hit enter to continue"

