set termoption dash

set termoption noenhanced

set style line 1 lw 3 lt 1 lc rgb "#D00000"

set style line 2 lw 3 lt 1 lc rgb "#00B000"

set style line 3 lw 3 lt 1 lc rgb "#2020FF"

set style line 4 lw 3 lt 1 lc rgb "#FF8000"

