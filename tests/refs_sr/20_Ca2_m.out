plot    "<grep '!J     1' t1" using 3:4 title "Prj 1" with lines ls 1,\
        "<grep '!J     1' t1" using 3:5 title "Prj 2" with lines ls 2


pause -1 "Hit enter to continue"

set title "t2   ARCTAN(Log Derivatives)"

